<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Base colours ─────────────────────────────────────────────────── -->
    <Color x:Key="WgsmAccent">#007A5E</Color>
    <Color x:Key="WgsmBg">#F2F3F5</Color>
    <Color x:Key="WgsmSurface">#FFFFFF</Color>
    <Color x:Key="WgsmSurface2">#E8EAED</Color>
    <Color x:Key="WgsmBorder">#D0D4DA</Color>
    <Color x:Key="WgsmMuted">#5A6474</Color>
    <Color x:Key="WgsmText">#1C1E21</Color>
    <Color x:Key="WgsmGreen">#007A5E</Color>
    <Color x:Key="WgsmRed">#C92A2A</Color>
    <Color x:Key="WgsmOrange">#9A5C00</Color>

    <!-- ── Brushes ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmAccentBrush"   Color="{StaticResource WgsmAccent}"/>
    <SolidColorBrush x:Key="WgsmBgBrush"       Color="{StaticResource WgsmBg}"/>
    <SolidColorBrush x:Key="WgsmSurfaceBrush"  Color="{StaticResource WgsmSurface}"/>
    <SolidColorBrush x:Key="WgsmSurface2Brush" Color="{StaticResource WgsmSurface2}"/>
    <SolidColorBrush x:Key="WgsmBorderBrush"   Color="{StaticResource WgsmBorder}"/>
    <SolidColorBrush x:Key="WgsmMutedBrush"    Color="{StaticResource WgsmMuted}"/>
    <SolidColorBrush x:Key="WgsmTextBrush"     Color="{StaticResource WgsmText}"/>
    <SolidColorBrush x:Key="WgsmGreenBrush"    Color="{StaticResource WgsmGreen}"/>
    <SolidColorBrush x:Key="WgsmRedBrush"      Color="{StaticResource WgsmRed}"/>
    <SolidColorBrush x:Key="WgsmOrangeBrush"   Color="{StaticResource WgsmOrange}"/>

    <!-- ── MahApps accent override ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent"     Color="{StaticResource WgsmAccent}"/>
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="{StaticResource WgsmAccent}"/>

    <!-- ── Action button colours ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmStartBg"      Color="#D3F9EE"/>
    <SolidColorBrush x:Key="WgsmStartFg"      Color="#005C45"/>
    <SolidColorBrush x:Key="WgsmStartBorder"  Color="#A0E8CE"/>

    <SolidColorBrush x:Key="WgsmStopBg"       Color="#FFE0E0"/>
    <SolidColorBrush x:Key="WgsmStopFg"       Color="#A82020"/>
    <SolidColorBrush x:Key="WgsmStopBorder"   Color="#F5AAAA"/>

    <SolidColorBrush x:Key="WgsmRestartBg"    Color="#FFF3CD"/>
    <SolidColorBrush x:Key="WgsmRestartFg"    Color="#7A4700"/>
    <SolidColorBrush x:Key="WgsmRestartBorder" Color="#FAD97A"/>

    <SolidColorBrush x:Key="WgsmActionBg"     Color="#E8EAED"/>
    <SolidColorBrush x:Key="WgsmActionFg"     Color="#5A6474"/>
    <SolidColorBrush x:Key="WgsmActionBorder" Color="#D0D4DA"/>

    <!-- ── Web API panel button colours ─────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmPrimaryBtnBg"  Color="#007A5E"/>
    <SolidColorBrush x:Key="WgsmPrimaryBtnFg"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WgsmGhostBtnBg"    Color="#E8EAED"/>
    <SolidColorBrush x:Key="WgsmGhostBtnFg"    Color="#5A6474"/>
    <SolidColorBrush x:Key="WgsmGhostBtnBorder" Color="#D0D4DA"/>
    <SolidColorBrush x:Key="WgsmDangerBtnBg"   Color="#FFE0E0"/>
    <SolidColorBrush x:Key="WgsmDangerBtnFg"   Color="#A82020"/>
    <SolidColorBrush x:Key="WgsmDangerBtnBorder" Color="#F5AAAA"/>

    <!-- ── Input field ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmInputBg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WgsmInputFg"       Color="#1C1E21"/>
    <SolidColorBrush x:Key="WgsmInputBorder"   Color="#D0D4DA"/>

    <!-- ── DataGrid colours ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmGridBg"        Color="#F2F3F5"/>
    <SolidColorBrush x:Key="WgsmGridRowBg"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WgsmGridRowAltBg"  Color="#F7F8FA"/>
    <SolidColorBrush x:Key="WgsmGridHeaderBg"  Color="#E8EAED"/>
    <SolidColorBrush x:Key="WgsmGridSelectBg"  Color="#D3F9EE"/>
    <SolidColorBrush x:Key="WgsmGridSelectFg"  Color="#005C45"/>

</ResourceDictionary>

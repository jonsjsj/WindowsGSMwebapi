<UserControl x:Class="WGSM.UI.AppSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="860"
             Background="{StaticResource WgsmBgBrush}">

    <UserControl.Resources>

        <!-- ── Sub-nav tab button ─────────────────────────────────────── -->
        <Style x:Key="TabNavButton" TargetType="RadioButton">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="{StaticResource WgsmMutedBrush}"/>
            <Setter Property="BorderThickness"    Value="0,0,0,2"/>
            <Setter Property="BorderBrush"        Value="Transparent"/>
            <Setter Property="FontSize"           Value="12"/>
            <Setter Property="FontWeight"         Value="SemiBold"/>
            <Setter Property="Padding"            Value="16,10"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{StaticResource WgsmAccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource WgsmAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Card surface ──────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource WgsmSurfaceBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource WgsmBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="16,12"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>

        <!-- ── Hint text ─────────────────────────────────────────────── -->
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground"     Value="#555"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="Margin"         Value="0,2,0,0"/>
            <Setter Property="TextWrapping"   Value="Wrap"/>
        </Style>

        <!-- ── Primary action button ─────────────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource WgsmAccentBrush}"/>
            <Setter Property="Foreground"      Value="#0D0D0D"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="18,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="32"/>
        </Style>

        <!-- ── Ghost action button ───────────────────────────────────── -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource WgsmSurface2Brush}"/>
            <Setter Property="Foreground"      Value="{StaticResource WgsmMutedBrush}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="BorderBrush"     Value="{StaticResource WgsmBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="32"/>
        </Style>

    </UserControl.Resources>

    <DockPanel Background="{StaticResource WgsmBgBrush}">

        <!-- ══ Sub-navigation bar ══════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource WgsmSurfaceBrush}"
                BorderBrush="{StaticResource WgsmBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <RadioButton x:Name="TabGeneral" Style="{StaticResource TabNavButton}" Content="General"             GroupName="AppTabs" IsChecked="True" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabStartup" Style="{StaticResource TabNavButton}" Content="Startup"             GroupName="AppTabs" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabAbout"   Style="{StaticResource TabNavButton}" Content="About &amp; Updates" GroupName="AppTabs" Checked="OnTabChanged"/>
            </StackPanel>
        </Border>

        <!-- ══ Tab content ═════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
            <Grid>

                <!-- ── General tab ─────────────────────────────────────── -->
                <StackPanel x:Name="PanelGeneral" MaxWidth="680">

                    <!-- Display -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="DISPLAY"/>

                            <!-- Dark Theme -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Dark Theme" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Use the WgsmDark color palette" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1"
                                                  x:Name="Switch_DarkTheme"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"
                                                  Toggled="OnDarkTheme_Toggled"/>
                            </Grid>

                            <!-- Hardware Acceleration -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Hardware Acceleration" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Disable if you see rendering glitches" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1"
                                                  x:Name="Switch_HardwareAcceleration"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"
                                                  Toggled="OnHardwareAcceleration_Toggled"/>
                            </Grid>

                            <!-- UI Animation -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="UI Animation" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Window transition animations" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1"
                                                  x:Name="Switch_UIAnimation"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"
                                                  Toggled="OnUIAnimation_Toggled"/>
                            </Grid>

                            <!-- Theme combobox (donor only) -->
                            <Grid Margin="0,14,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="WGSM Theme" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Patron donors only — enable Donor Connect to unlock" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <ComboBox x:Name="ThemeComboBox"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Height="28"
                                          VerticalAlignment="Center"
                                          SelectionChanged="OnThemeSelectionChanged"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Behavior -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="BEHAVIOR"/>

                            <!-- Restart on Crash -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Auto Restart on Crash" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Automatically restart WGSM if it crashes" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1"
                                                  x:Name="Switch_RestartOnCrash"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"
                                                  Toggled="OnRestartOnCrash_Toggled"/>
                            </Grid>

                            <!-- Send Statistics -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Send Statistics" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Help improve WGSM by sending anonymous usage data" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1"
                                                  x:Name="Switch_SendStatistics"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"
                                                  Toggled="OnSendStatistics_Toggled"/>
                            </Grid>

                            <!-- Donor Connect -->
                            <Grid Margin="0,10,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Donor Connect (Patreon)" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Unlock donor themes and features with a Patreon activation key" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1"
                                                  x:Name="Switch_DonorConnect"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"
                                                  Toggled="OnDonorConnect_Toggled"/>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Security -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="SECURITY"/>

                            <Grid Margin="0,10,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Require Password" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Password-protect the Start server and Edit Config actions" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Button x:Name="SetPasswordButton" Content="Change" Style="{StaticResource GhostBtn}"
                                            Margin="0,0,8,0" Click="OnSetPassword" Visibility="Collapsed"/>
                                    <mah:ToggleSwitch x:Name="Switch_ServerLock"
                                                      OnContent="" OffContent=""
                                                      VerticalAlignment="Center"
                                                      Toggled="OnServerLock_Toggled"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Startup tab ─────────────────────────────────────────── -->
                <StackPanel x:Name="PanelStartup" MaxWidth="680" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="WINDOWS LOGIN"/>

                            <Grid Margin="0,10,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Start WGSM on Login" Foreground="#E0E0E0" FontSize="13"/>
                                    <TextBlock Text="Automatically launch WGSM when Windows starts (requires admin)" Style="{StaticResource HintText}"/>
                                </StackPanel>
                                <mah:ToggleSwitch Grid.Column="1"
                                                  x:Name="Switch_StartOnBoot"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center"
                                                  Toggled="OnStartOnBoot_Toggled"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Auto-Start Servers -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="AUTO-START SERVERS"/>
                            <TextBlock Text="Toggle auto-start per server. Changes take effect immediately."
                                       Style="{StaticResource HintText}" Margin="0,2,0,8"/>
                            <StackPanel x:Name="AutoStartServersList"/>
                            <TextBlock x:Name="AutoStartNoServersLabel"
                                       Text="No servers configured yet." Foreground="#555" FontSize="11"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── About &amp; Updates tab ────────────────────────────── -->
                <StackPanel x:Name="PanelAbout" MaxWidth="680" Visibility="Collapsed">

                    <!-- App Update -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="APPLICATION UPDATE"/>
                            <TextBlock Foreground="#555" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,10"
                                       Text="Check GitHub for a new WGSM version. Apply will stop servers, run the installer and restart automatically."/>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryBtn}"
                                        Content="Check for update" Click="OnCheckUpdate"
                                        Margin="0,0,10,0"/>
                                <Button x:Name="ApplyUpdateButton" Style="{StaticResource GhostBtn}"
                                        Content="Apply update" Click="OnApplyUpdate"
                                        IsEnabled="False"/>
                            </StackPanel>
                            <TextBlock x:Name="UpdateStatusLabel" Foreground="{StaticResource WgsmMutedBrush}"
                                       FontSize="12" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="ABOUT"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Version"
                                           Foreground="{StaticResource WgsmMutedBrush}"
                                           FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="VersionLabel" Grid.Column="1"
                                           Foreground="#E0E0E0" FontSize="12"
                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Links -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="LINKS"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Style="{StaticResource GhostBtn}" Content="Website"
                                        Click="OnLinkWebsite" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource GhostBtn}" Content="Discord"
                                        Click="OnLinkDiscord" Margin="0,0,8,0"/>
                                <Button Style="{StaticResource GhostBtn}" Content="Patreon"
                                        Click="OnLinkPatreon"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>
        </ScrollViewer>

    </DockPanel>
</UserControl>

<UserControl x:Class="WindowsGSM.UI.PortsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="860"
             Background="{StaticResource WgsmBgBrush}">

    <UserControl.Resources>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource WgsmSurfaceBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource WgsmBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="16,12"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#555"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Margin"       Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource WgsmMutedBrush}"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <DataTemplate x:Key="PortRowTemplate">
            <Grid Margin="0,7,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="62"/>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}"
                           Foreground="#E0E0E0" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Port}"
                           Foreground="{StaticResource WgsmMutedBrush}"
                           FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding Protocol}"
                           Foreground="{StaticResource WgsmMutedBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{Binding LocalBrush}"
                             Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LocalText}" FontSize="11"
                               Foreground="{Binding LocalBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{Binding ExternalBrush}"
                             Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExternalText}" FontSize="11"
                               Foreground="{Binding ExternalBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

    </UserControl.Resources>

    <DockPanel Background="{StaticResource WgsmBgBrush}">

        <!-- ══ Header bar ══════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource WgsmSurfaceBrush}"
                BorderBrush="{StaticResource WgsmBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Port Monitor" Foreground="#E0E0E0" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock x:Name="PublicIpLabel" Text="Public IP: —"
                               Foreground="{StaticResource WgsmMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Content="Refresh All" Click="OnRefresh"
                        Background="{StaticResource WgsmSurface2Brush}"
                        Foreground="{StaticResource WgsmMutedBrush}"
                        BorderBrush="{StaticResource WgsmBorderBrush}"
                        BorderThickness="1" Padding="14,7" Height="32" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- ══ Content ═════════════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel MaxWidth="720">

                <!-- Column headers -->
                <Grid Margin="0,0,0,4" Opacity="0.6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="62"/>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SERVICE"  Style="{StaticResource ColHeader}"/>
                    <TextBlock Grid.Column="1" Text="PORT"     Style="{StaticResource ColHeader}"/>
                    <TextBlock Grid.Column="2" Text="PROTO"    Style="{StaticResource ColHeader}"/>
                    <TextBlock Grid.Column="3" Text="LOCAL"    Style="{StaticResource ColHeader}"/>
                    <TextBlock Grid.Column="4" Text="EXTERNAL" Style="{StaticResource ColHeader}"/>
                </Grid>

                <!-- Game Servers -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="GAME SERVERS"/>
                        <ItemsControl x:Name="GameServerPortsList"
                                      ItemTemplate="{StaticResource PortRowTemplate}"/>
                        <TextBlock x:Name="NoGameServersLabel"
                                   Text="No game servers configured." Style="{StaticResource HintText}"
                                   Margin="0,6,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Web API -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="WEB API"/>
                        <ItemsControl x:Name="WebApiPortsList"
                                      ItemTemplate="{StaticResource PortRowTemplate}"/>
                    </StackPanel>
                </Border>

                <!-- Docker -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="DOCKER"/>
                        <TextBlock x:Name="DockerStatusLabel"
                                   Text="Detecting Docker containers..." Style="{StaticResource HintText}"
                                   Margin="0,4,0,0"/>
                        <ItemsControl x:Name="DockerPortsList"
                                      ItemTemplate="{StaticResource PortRowTemplate}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>

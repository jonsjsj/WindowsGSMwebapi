<UserControl x:Class="WindowsGSM.UI.WebApiSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="860"
             Background="{StaticResource WgsmBgBrush}">

    <UserControl.Resources>

        <!-- ── Sub-nav tab button ─────────────────────────────────────── -->
        <Style x:Key="TabNavButton" TargetType="RadioButton">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="{StaticResource WgsmMutedBrush}"/>
            <Setter Property="BorderThickness"    Value="0,0,0,2"/>
            <Setter Property="BorderBrush"        Value="Transparent"/>
            <Setter Property="FontSize"           Value="12"/>
            <Setter Property="FontWeight"         Value="SemiBold"/>
            <Setter Property="Padding"            Value="16,10"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{StaticResource WgsmAccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource WgsmAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Card surface ──────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource WgsmSurfaceBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource WgsmBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="16,12"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>

        <!-- ── Field row label ───────────────────────────────────────── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground"        Value="{StaticResource WgsmMutedBrush}"/>
            <Setter Property="MinWidth"          Value="140"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>

        <!-- ── Hint text ─────────────────────────────────────────────── -->
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- ── Primary action button ─────────────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"    Value="{StaticResource WgsmAccentBrush}"/>
            <Setter Property="Foreground"    Value="#0D0D0D"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Padding"       Value="18,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Height"        Value="32"/>
        </Style>

        <!-- ── Ghost action button ───────────────────────────────────── -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"    Value="{StaticResource WgsmSurface2Brush}"/>
            <Setter Property="Foreground"    Value="{StaticResource WgsmMutedBrush}"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Padding"       Value="14,7"/>
            <Setter Property="BorderBrush"   Value="{StaticResource WgsmBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Height"        Value="32"/>
        </Style>

        <!-- ── Danger button ─────────────────────────────────────────── -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background"    Value="#2D1215"/>
            <Setter Property="Foreground"    Value="{StaticResource WgsmRedBrush}"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Padding"       Value="18,7"/>
            <Setter Property="BorderBrush"   Value="#5A1E1E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Height"        Value="32"/>
        </Style>

        <!-- ── Status pill ───────────────────────────────────────────── -->
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="10,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── Section label inside a card ──────────────────────────── -->
        <Style x:Key="CardSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource WgsmMutedBrush}"/>
            <Setter Property="Margin"     Value="0,10,0,4"/>
        </Style>

    </UserControl.Resources>

    <DockPanel Background="{StaticResource WgsmBgBrush}">

        <!-- ══ Sub-navigation bar ══════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource WgsmSurfaceBrush}"
                BorderBrush="{StaticResource WgsmBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <RadioButton x:Name="TabGeneral"    Style="{StaticResource TabNavButton}" Content="General"    GroupName="WebApiTabs" IsChecked="True" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabKeys"       Style="{StaticResource TabNavButton}" Content="API Keys"   GroupName="WebApiTabs" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabConnection" Style="{StaticResource TabNavButton}" Content="Connection" GroupName="WebApiTabs" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabBackup"     Style="{StaticResource TabNavButton}" Content="Backup"     GroupName="WebApiTabs" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabUpdates"    Style="{StaticResource TabNavButton}" Content="Updates"    GroupName="WebApiTabs" Checked="OnTabChanged"/>
                <RadioButton x:Name="TabLog"        Style="{StaticResource TabNavButton}" Content="Log"        GroupName="WebApiTabs" Checked="OnTabChanged"/>
            </StackPanel>
        </Border>

        <!-- ══ Tab content ═════════════════════════════════════════════ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
            <Grid>

                <!-- ── General tab ─────────────────────────────────────────── -->
                <StackPanel x:Name="PanelGeneral" MaxWidth="680">

                    <!-- Server running status card -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Web API Server" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#E0E0E0" Margin="0,0,0,2"/>
                                <TextBlock x:Name="StatusLabel" Text="Not running"
                                           Foreground="{StaticResource WgsmMutedBrush}" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="StartButton" Style="{StaticResource PrimaryBtn}"
                                        Content="Start" Click="OnStartApi" Margin="0,0,8,0"/>
                                <Button x:Name="StopButton" Style="{StaticResource DangerBtn}"
                                        Content="Stop" Click="OnStopApi" IsEnabled="False"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Instance identity -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="INSTANCE IDENTITY"/>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Name shown on the WGSM.WEB dashboard to identify this machine."/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Instance name"/>
                                <TextBox x:Name="InstanceNameBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}"
                                        Content="Save" Click="OnSaveInstanceName"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Startup -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="STARTUP"/>
                            <CheckBox x:Name="AutoStartCheckBox"
                                      Content="Start Web API automatically when WGSM launches"
                                      Foreground="#CCCCCC"
                                      Checked="OnAutoStartToggled" Unchecked="OnAutoStartToggled"/>
                        </StackPanel>
                    </Border>

                    <!-- Connection URLs -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="CONNECTION URLS"/>
                            <Grid Margin="0,4,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Localhost"/>
                                <TextBlock x:Name="LocalUrlLabel" Grid.Column="1"
                                           Foreground="{StaticResource WgsmAccentBrush}"
                                           Text="—" Cursor="Hand" MouseDown="OnUrlClick"/>
                            </Grid>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="LAN"/>
                                <TextBlock x:Name="LanUrlLabel" Grid.Column="1"
                                           Foreground="{StaticResource WgsmAccentBrush}"
                                           Text="—" Cursor="Hand" MouseDown="OnUrlClick"/>
                            </Grid>
                            <Grid Margin="0,3,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Public"/>
                                <TextBlock x:Name="PublicUrlLabel" Grid.Column="1"
                                           Foreground="{StaticResource WgsmAccentBrush}"
                                           Text="—" Cursor="Hand" MouseDown="OnUrlClick"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── API Keys tab ─────────────────────────────────────────── -->
                <StackPanel x:Name="PanelKeys" MaxWidth="680" Visibility="Collapsed">

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="API KEYS"/>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Each key allows one client (e.g. WGSM.WEB dashboard) to connect. Use separate keys per device so you can revoke individually."/>
                            <!-- Keys list — populated by RefreshKeysList() in code-behind -->
                            <Border Background="{StaticResource WgsmBgBrush}"
                                    BorderBrush="{StaticResource WgsmBorderBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="4" MinHeight="40" Margin="0,0,0,12">
                                <StackPanel x:Name="KeysPanel"/>
                            </Border>

                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="ADD NEW KEY"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Key name"/>
                                <TextBox x:Name="NewKeyNameBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         Margin="0,0,8,0" Text="Dashboard"/>
                                <Button Grid.Column="2" Style="{StaticResource PrimaryBtn}"
                                        Content="Add key" Click="OnAddKey"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Connection tab ───────────────────────────────────────── -->
                <StackPanel x:Name="PanelConnection" MaxWidth="680" Visibility="Collapsed">

                    <!-- Port -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="PORT"/>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Default: 7876. Open this port in your firewall for LAN or external access."/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="API port"/>
                                <TextBox x:Name="PortBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         Text="7876" PreviewTextInput="OnPortPreviewInput"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Scope -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="ACCESS SCOPE"/>
                            <RadioButton x:Name="ScopeLocal"
                                         Content="Local only  (localhost access)"
                                         Foreground="#CCCCCC" Margin="0,4"
                                         Checked="OnScopeChanged"/>
                            <RadioButton x:Name="ScopeLan"
                                         Content="Allow LAN access  (same network)"
                                         Foreground="#CCCCCC" Margin="0,4"
                                         Checked="OnScopeChanged"/>
                            <RadioButton x:Name="ScopeExternal"
                                         Content="Allow external access  (public internet — use HTTPS)"
                                         Foreground="#CCCCCC" Margin="0,4"
                                         Checked="OnScopeChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- HTTPS -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="HTTPS (OPTIONAL)"/>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Import a certificate and private key (.pem) to enable HTTPS."/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Certificate (.pem)"/>
                                <TextBox x:Name="CertPathBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         IsReadOnly="True" Margin="0,0,8,0"
                                         Text="No certificate imported"/>
                                <Button Grid.Column="2" Style="{StaticResource GhostBtn}"
                                        Content="Import cert" Click="OnImportCert"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Private key (.pem)"/>
                                <TextBox x:Name="KeyPathBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         IsReadOnly="True" Margin="0,0,8,0"
                                         Text="No key imported"/>
                                <Button Grid.Column="2" Style="{StaticResource GhostBtn}"
                                        Content="Import key" Click="OnImportKey"/>
                            </Grid>
                            <CheckBox x:Name="HttpsCheckBox"
                                      Content="Enable HTTPS redirect  (HTTP → HTTPS)"
                                      Foreground="#CCCCCC"
                                      Checked="OnHttpsToggled" Unchecked="OnHttpsToggled"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Backup tab ────────────────────────────────────────────── -->
                <StackPanel x:Name="PanelBackup" MaxWidth="680" Visibility="Collapsed">

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="BACKUP DESTINATIONS"/>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="ZIP server configs and saves. Leave a path empty to skip that destination."/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Local path"/>
                                <TextBox x:Name="BackupLocalPathBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         Margin="0,0,8,0"
                                         ToolTip="e.g. C:\Backups\WGSM"/>
                                <Button Grid.Column="2" Style="{StaticResource GhostBtn}"
                                        Content="Browse" Click="OnBrowseBackupLocal"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="OneDrive path"/>
                                <TextBox x:Name="BackupOnedrivPathBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         ToolTip="e.g. C:\Users\You\OneDrive\WGSM Backups"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Google Drive path"/>
                                <TextBox x:Name="BackupGdrivePathBox" Grid.Column="1"
                                         Style="{StaticResource WgsmInputBox}"
                                         ToolTip="e.g. G:\My Drive\WGSM Backups"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Style="{StaticResource PrimaryBtn}"
                                        Content="Save paths" Click="OnSaveBackupPaths"
                                        Margin="0,0,10,0"/>
                                <Button Style="{StaticResource GhostBtn}"
                                        Content="Create backup now" Click="OnCreateBackup"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Updates tab ──────────────────────────────────────────── -->
                <StackPanel x:Name="PanelUpdates" MaxWidth="680" Visibility="Collapsed">

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource WgsmSectionHeader}" Text="APPLICATION UPDATE"/>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Check GitHub for a new WGSM version. Apply will stop servers, swap the exe and restart automatically."/>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource PrimaryBtn}"
                                        Content="Check for update" Click="OnCheckUpdate"
                                        Margin="0,0,10,0"/>
                                <Button x:Name="ApplyUpdateButton" Style="{StaticResource GhostBtn}"
                                        Content="Apply update" Click="OnApplyUpdate"
                                        IsEnabled="False"/>
                            </StackPanel>
                            <TextBlock x:Name="UpdateStatusLabel" Foreground="{StaticResource WgsmMutedBrush}"
                                       FontSize="12" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── Log tab ──────────────────────────────────────────────── -->
                <Grid x:Name="PanelLog" Visibility="Collapsed">
                    <Border Style="{StaticResource Card}" Margin="0,0,20,0">
                        <TextBox x:Name="LogBox"
                                 Background="{StaticResource WgsmBgBrush}"
                                 Foreground="#CCCCCC"
                                 BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11"
                                 Height="500"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>

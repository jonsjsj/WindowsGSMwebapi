<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Base colours ─────────────────────────────────────────────────── -->
    <Color x:Key="WgsmAccent">#00D4AA</Color>
    <Color x:Key="WgsmBg">#0D0D0D</Color>
    <Color x:Key="WgsmSurface">#111111</Color>
    <Color x:Key="WgsmSurface2">#1A1A1A</Color>
    <Color x:Key="WgsmBorder">#222222</Color>
    <Color x:Key="WgsmMuted">#888888</Color>
    <Color x:Key="WgsmText">#E0E0E0</Color>
    <Color x:Key="WgsmGreen">#00D4AA</Color>
    <Color x:Key="WgsmRed">#FF4D4D</Color>
    <Color x:Key="WgsmOrange">#FF9F43</Color>

    <!-- ── Brushes ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmAccentBrush"   Color="{StaticResource WgsmAccent}"/>
    <SolidColorBrush x:Key="WgsmBgBrush"       Color="{StaticResource WgsmBg}"/>
    <SolidColorBrush x:Key="WgsmSurfaceBrush"  Color="{StaticResource WgsmSurface}"/>
    <SolidColorBrush x:Key="WgsmSurface2Brush" Color="{StaticResource WgsmSurface2}"/>
    <SolidColorBrush x:Key="WgsmBorderBrush"   Color="{StaticResource WgsmBorder}"/>
    <SolidColorBrush x:Key="WgsmMutedBrush"    Color="{StaticResource WgsmMuted}"/>
    <SolidColorBrush x:Key="WgsmTextBrush"     Color="{StaticResource WgsmText}"/>
    <SolidColorBrush x:Key="WgsmGreenBrush"    Color="{StaticResource WgsmGreen}"/>
    <SolidColorBrush x:Key="WgsmRedBrush"      Color="{StaticResource WgsmRed}"/>
    <SolidColorBrush x:Key="WgsmOrangeBrush"   Color="{StaticResource WgsmOrange}"/>

    <!-- ── MahApps accent override ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent"     Color="{StaticResource WgsmAccent}"/>
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="{StaticResource WgsmAccent}"/>

    <!-- ── Action button colours ────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmStartBg"      Color="#0D2A1F"/>
    <SolidColorBrush x:Key="WgsmStartFg"      Color="#00D4AA"/>
    <SolidColorBrush x:Key="WgsmStartBorder"  Color="#1A4033"/>

    <SolidColorBrush x:Key="WgsmStopBg"       Color="#2D1215"/>
    <SolidColorBrush x:Key="WgsmStopFg"       Color="#FF4D4D"/>
    <SolidColorBrush x:Key="WgsmStopBorder"   Color="#5A1E1E"/>

    <SolidColorBrush x:Key="WgsmRestartBg"    Color="#2A1E0D"/>
    <SolidColorBrush x:Key="WgsmRestartFg"    Color="#FF9F43"/>
    <SolidColorBrush x:Key="WgsmRestartBorder" Color="#4A3515"/>

    <SolidColorBrush x:Key="WgsmActionBg"     Color="#1A1A1A"/>
    <SolidColorBrush x:Key="WgsmActionFg"     Color="#888888"/>
    <SolidColorBrush x:Key="WgsmActionBorder" Color="#222222"/>

    <!-- ── Web API panel button colours ─────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmPrimaryBtnBg"  Color="#00D4AA"/>
    <SolidColorBrush x:Key="WgsmPrimaryBtnFg"  Color="#0D0D0D"/>
    <SolidColorBrush x:Key="WgsmGhostBtnBg"    Color="#1A1A1A"/>
    <SolidColorBrush x:Key="WgsmGhostBtnFg"    Color="#888888"/>
    <SolidColorBrush x:Key="WgsmGhostBtnBorder" Color="#222222"/>
    <SolidColorBrush x:Key="WgsmDangerBtnBg"   Color="#2D1215"/>
    <SolidColorBrush x:Key="WgsmDangerBtnFg"   Color="#FF4D4D"/>
    <SolidColorBrush x:Key="WgsmDangerBtnBorder" Color="#5A1E1E"/>

    <!-- ── Input field ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmInputBg"       Color="#0D0D0D"/>
    <SolidColorBrush x:Key="WgsmInputFg"       Color="#E0E0E0"/>
    <SolidColorBrush x:Key="WgsmInputBorder"   Color="#222222"/>

    <!-- ── DataGrid colours ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WgsmGridBg"        Color="#111111"/>
    <SolidColorBrush x:Key="WgsmGridRowBg"     Color="#111111"/>
    <SolidColorBrush x:Key="WgsmGridRowAltBg"  Color="#161616"/>
    <SolidColorBrush x:Key="WgsmGridHeaderBg"  Color="#1A1A1A"/>
    <SolidColorBrush x:Key="WgsmGridSelectBg"  Color="#0D2A1F"/>
    <SolidColorBrush x:Key="WgsmGridSelectFg"  Color="#00D4AA"/>

</ResourceDictionary>
